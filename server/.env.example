# ─── Stripe (paiements Premium) ────────────────────────────
# Récupère ces valeurs sur https://dashboard.stripe.com
# ⚠️ NE JAMAIS COMMIT ce fichier
# ⚠️ NE JAMAIS PARTAGER ces valeurs sur Telegram/Discord/etc.

# 1. Clé secrète serveur → https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# 2. Signing secret du webhook → https://dashboard.stripe.com/webhooks
#    Endpoint à créer : https://pokevendrepro.com/celeste/api/billing/webhook
#    Events à écouter :
#      - checkout.session.completed
#      - customer.subscription.updated
#      - customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_...

# 3. Price IDs des produits → https://dashboard.stripe.com/products
#    Crée 2 produits récurrents :
#      - Annuel : 39,99€/an avec trial de 3 jours
#      - Hebdo  : 6,99€/semaine
STRIPE_PRICE_ANNUAL=price_...
STRIPE_PRICE_WEEKLY=price_...