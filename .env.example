# Frontend (client) — variables exposées au navigateur via Vite
# Le préfixe VITE_ est obligatoire pour qu'elles soient accessibles

# Publishable key Stripe (côté client uniquement, pas secrète)
# → https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# URL de l'API backend
VITE_API_URL=https://pokevendrepro.com/celeste/api

# ─── Monitoring (optionnel — laissé vide = désactivé) ───
# Sentry: error tracking → https://sentry.io (créer un projet React)
# VITE_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX

# PostHog: product analytics → https://posthog.com (créer un projet)
# VITE_POSTHOG_KEY=phc_xxx
# VITE_POSTHOG_HOST=https://app.posthog.com